# Agent Workbench — local development environment template
# Copy this to .env and fill in values. Never commit .env.
#
# For local Docker Compose development, only APP_ENV and DATABASE_URL are required.
# The other AGENT_WORKBENCH_*_DATABASE_URL variables are used by bootstrap scripts
# and Alembic when targeting non-local environments.

APP_ENV=local
DATABASE_URL=postgresql+psycopg://agent_workbench:agent_workbench_local@localhost:5432/agent_workbench

# Optional: override the local Docker Compose DB password (must match POSTGRES_PASSWORD)
# POSTGRES_PASSWORD=agent_workbench_local

# Optional: API server bind settings
# API_HOST=0.0.0.0
# API_PORT=8000

# Optional: Prometheus metrics endpoint (disabled by default)
# PROMETHEUS_ENABLED=false

# Non-local environment database URLs (set these when running migrations against dev/stage/prod)
# These are NEVER committed. Obtain from your secrets manager or deployment tooling.
# AGENT_WORKBENCH_DEV_DATABASE_URL=postgresql+psycopg://user:pass@postgresql-dev/agent_workbench_dev
# AGENT_WORKBENCH_STAGE_DATABASE_URL=postgresql+psycopg://user:pass@postgresql-stage/agent_workbench_stage
# AGENT_WORKBENCH_PROD_DATABASE_URL=postgresql+psycopg://user:pass@postgresql/agent_workbench_prod
